# Base URL the app calls. Keep it RELATIVE in dev — Vite proxies it to
# VITE_API_PROXY_TARGET, so the browser sees a same-origin request (no CORS).
# For a real deployment set this to the absolute API URL and enable CORS server-side.
VITE_API_BASE_URL=/api/v1
# Dev-only: where the proxy forwards. Update when the ngrok URL changes (use https).
VITE_API_PROXY_TARGET=https://14f6-82-215-116-241.ngrok-free.app
# Toggle mock services (true = use built-in mock data, false = hit real endpoints)
VITE_USE_MOCK=true
